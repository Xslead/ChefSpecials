rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /recipe_images/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /step_images/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /user_avatars/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
